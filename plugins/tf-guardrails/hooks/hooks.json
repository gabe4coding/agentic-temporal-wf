{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|MultiEdit|Write|Grep|Glob|Bash|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/restrict_paths.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
