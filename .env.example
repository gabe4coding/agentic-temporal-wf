# Anthropic
ANTHROPIC_API_KEY=
# Optional. Claude Code CLI retry budget. build_options() also passes
# this via SDK env, but exposing here documents the override mechanism.
# CLAUDE_CODE_MAX_RETRIES=0

# GitHub (fine-grained PAT with PR read/write + checks write)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Temporal (used by worker + gateway containers)
TEMPORAL_TARGET=temporal:7233
TEMPORAL_TASK_QUEUE=pr-autofix

# CVE-2026-21852 mitigation: pin the API base URL so a hijacked project
# config cannot redirect traffic. Set to the official Anthropic API host.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Comma-separated allowlist of {owner}/{repo} slugs the agent is allowed
# to act on. Empty/unset = deny all.
ALLOWED_REPOS=lafourchette/playground

# Observability (OpenInference). Two supported backends:
#
# 1. Phoenix self-hosted (local, zero credentials). The compose stack
#    ships a `phoenix` service; the default endpoint below resolves to
#    it from inside docker-compose. UI at http://localhost:6006.
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
ARIZE_PROJECT=agent-temporal-dev
#
# 2. Arize cloud (managed). Set both keys to override Phoenix.
ARIZE_API_KEY=
ARIZE_SPACE_ID=
