# Anthropic
ANTHROPIC_API_KEY=
# Optional. Claude Code CLI retry budget. build_options() also passes
# this via SDK env, but exposing here documents the override mechanism.
# CLAUDE_CODE_MAX_RETRIES=0

# GitHub (fine-grained PAT with PR read/write + checks write)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Temporal (used by worker + gateway containers)
TEMPORAL_TARGET=temporal:7233
TEMPORAL_TASK_QUEUE=pr-autofix

# Host-visible absolute path mounted into the trusted worker. A sandbox sees
# only its individual run directory bind-mounted at /work.
WORKSPACE_ROOT=/tmp/agent-temporal-workspaces

# Shared only by trusted worker and broker for registering run capabilities.
BROKER_REGISTRATION_SECRET=replace-with-random-secret

# Users whose PR issue comments can approve or deny publication.
APPROVER_LOGINS=

# Comma-separated allowlist of {owner}/{repo} slugs the agent is allowed
# to act on. Empty/unset = deny all.
ALLOWED_REPOS=lafourchette/playground

# Observability (OpenInference). Two supported backends:
#
# 1. Phoenix self-hosted (local, zero credentials). The compose stack
#    ships a `phoenix` service; the default endpoint below resolves to
#    it from inside docker-compose. UI at http://localhost:6006.
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
ARIZE_PROJECT=agent-temporal-dev
# CLI traces are routed via otel-collector → Phoenix so CLI-native
# attribute names get rewritten to OpenInference convention (cost calc,
# span kind). Override only if you want to bypass the collector.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
#
# 2. Arize cloud (managed trusted-service telemetry only; these credentials
#    are never provisioned into an untrusted sandbox).
ARIZE_API_KEY=
ARIZE_SPACE_ID=
